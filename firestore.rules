rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - immutable
    //   - email: string (required) - immutable
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required) - immutable
    //
    // Collection: deployments
    // Document ID: {deploymentId}
    // Fields:
    //   - uid: string (required) - immutable
    //   - name: string (required)
    //   - configData: string (required)
    //   - createdAt: timestamp (required) - immutable
    //   - updatedAt: timestamp (required)
    //
    // Collection: biosConfigs
    // Document ID: {biosConfigId}
    // Fields:
    //   - uid: string (required) - immutable
    //   - name: string (required)
    //   - configData: string (required)
    //   - createdAt: timestamp (required) - immutable
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'createdAt']) &&
             hasRequiredFields(['uid', 'email', 'createdAt']) &&
             request.resource.data.uid is string && request.resource.data.uid == request.auth.uid &&
             request.resource.data.email is string && request.resource.data.email.size() < 100 &&
             isValidOptionalString('displayName', 0, 200) &&
             isValidOptionalString('photoURL', 0, 2000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidConfig() {
      return hasOnlyAllowedFields(['uid', 'name', 'configData', 'createdAt', 'updatedAt']) &&
             hasRequiredFields(['uid', 'name', 'configData', 'createdAt', 'updatedAt']) &&
             request.resource.data.uid is string && request.resource.data.uid == request.auth.uid &&
             validStringLength('name', 1, 100) &&
             validStringLength('configData', 1, 100000) && // Up to 100KB for config data
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified() && areImmutableFieldsUnchanged(['uid', 'email', 'createdAt']);
      allow delete: if false; // Users cannot delete their own profile directly for now
    }

    match /deployments/{deploymentId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidConfig() && uidUnchanged();
      allow update: if isDocOwner() && isValidConfig() && uidNotModified() && areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isDocOwner();
    }

    match /biosConfigs/{biosConfigId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidConfig() && uidUnchanged();
      allow update: if isDocOwner() && isValidConfig() && uidNotModified() && areImmutableFieldsUnchanged(['uid', 'createdAt']);
      allow delete: if isDocOwner();
    }
  }
}
