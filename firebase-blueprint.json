{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile photo."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "DeploymentConfig": {
      "title": "DeploymentConfig",
      "description": "A saved deployment configuration.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user who owns this configuration."
        },
        "name": {
          "type": "string",
          "description": "The name of the configuration."
        },
        "configData": {
          "type": "string",
          "description": "JSON stringified configuration data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the configuration was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the configuration was last updated."
        }
      },
      "required": ["uid", "name", "configData", "createdAt", "updatedAt"]
    },
    "BiosConfig": {
      "title": "BiosConfig",
      "description": "A saved BIOS configuration.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier of the user who owns this configuration."
        },
        "name": {
          "type": "string",
          "description": "The name of the configuration."
        },
        "configData": {
          "type": "string",
          "description": "JSON stringified configuration data."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the configuration was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the configuration was last updated."
        }
      },
      "required": ["uid", "name", "configData", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/deployments/{deploymentId}": {
      "schema": {
        "$ref": "#/entities/DeploymentConfig"
      },
      "description": "Stores saved deployment configurations."
    },
    "/biosConfigs/{biosConfigId}": {
      "schema": {
        "$ref": "#/entities/BiosConfig"
      },
      "description": "Stores saved BIOS configurations."
    }
  }
}
